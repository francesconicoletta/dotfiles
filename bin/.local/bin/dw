#!/bin/sh

YOUTUBE_REGEX='^(https?\:\/\/)?(www\.)?(youtube\.com|youtu\.?be)\/.+$'

notifymacos () {
osascript -ss - "$1" <<EOF
on run argv
display notification quoted form of item 1 of argv with title "Download completed" sound name "Blow"
end run
EOF
}

notifylinux () {
	notify-send "Download completed" "$1" -u low -i dialog-information
}

if echo "$1" | grep -qE "$YOUTUBE_REGEX"; then
	yt-dlp -f bestvideo[ext=mp4]+bestaudio[ext=m4a] -o "$HOME/Movies/%(title)s-%(id)s.%(ext)s" "$1"
else
	aria2c -x 16 -s 16 -k 1M -d "$HOME/Downloads" "$1";
fi

if [ $? -eq 0 ]; then
	if [ $(uname) = "Darwin" ]
	then notifymacos "$1"
	else notifylinux "$1"
	fi
fi
