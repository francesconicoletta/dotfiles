#!/bin/sh

YOUTUBE_REGEX='^(https?\:\/\/)?(www\.)?(youtube\.com|youtu\.?be)\/.+$'

[ $# -eq 0 ] && URL="$(pbpaste)" || URL="$1"

if echo "$URL" | grep -qE "$YOUTUBE_REGEX"; then
	yt-dlp -S vcodec:h264,res,acodec:m4a \
		--add-metadata \
		--embed-subs \
		--embed-thumbnail \
		--sponsorblock-remove default \
		-o "$HOME/Movies/%(title)s-%(id)s.%(ext)s" "$URL"
else
	aria2c -x 16 -s 16 -k 1M -d "$HOME/Downloads" "$URL";
fi

osascript -ss - "$URL" <<EOF
on run argv
display notification quoted form of item 1 of argv with title "Download completed" sound name "Blow"
end run
EOF
