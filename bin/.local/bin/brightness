#!/bin/bash

getbar() {
	percent=$(($(brightnessctl get)*100/852))
	echo -n '['
	for ((i = 1; i <= percent; i = i + 5)); do echo -n "#"; done
	for ((j = i ; j <= 100 ; j = j + 5)); do echo -n " "; done
	echo "] $percent%"
}

if [ "$1" = 'up' ]; then
	brightnessctl set +5%
elif [ "$1" = 'down' ]; then
	brightnessctl set 5%-
fi

dunstify -u low -t 3000 -r 90210 "Brightness: $(getbar)"

