#!/bin/sh

if [ "$1" = 'screen' ]; then
	# Print		Screenshot entire screen
	# screenshot screen
	maim ~/Pictures/screenshot"$(date '+%Y%m%d%H%M%S')".png
	notify-send "Screenshot saved" -u low -t 1000

elif [ "$1" = 'copyscreen' ]; then
	# Control+Print		Screenshot entire screen and copy it to clipboard
	# screenshot copyscreen
	maim | xclip -selection clipboard -t image/png
	notify-send "Screenshot copied" -u low -t 1000

elif [ "$1" = 'window' ]; then
	# Mod+Print	Select window and take a screenshot
	# screenshot window
	maim -st 9999999 | convert - \( +clone -background black -shadow 50x20+5+5 \) +swap -background none -layers merge +repage ~/Pictures/screenshot"$(date '+%Y%m%d%H%M%S')".png
	notify-send "Screenshot saved" -u low -t 1000

elif [ "$1" = 'copywindow' ]; then
	# Mod+Control+Print	Select window, take a screenshot and copy it to clipboard
	# screenshot copywindow
	maim -st 9999999 | convert - \( +clone -background black -shadow 50x20+5+5 \) +swap -background none -layers merge +repage /tmp/tempscreenshot.png
	if [ -f /tmp/tempscreenshot.png ]; then
		xclip -selection clipboard -t image/png -i /tmp/tempscreenshot.png
		notify-send "Screenshot copied" -u low -t 1000
		rm /tmp/tempscreenshot.png
	fi

elif [ "$1" = 'selection' ]; then
	# Shift+Print		Select area and take a screenshot
	# screenshot selection
	maim -s ~/Pictures/screenshot"$(date '+%Y%m%d%H%M%S')".png
	notify-send "Screenshot saved" -u low -t 1000

elif [ "$1" = 'copyselection' ]; then
	# Control+Shift+Print		Select area, take a screenshot and copy it to clipboard
	# screenshot copyselection
	maim -s /tmp/tempscreenshot.png
	if [ -f /tmp/tempscreenshot.png ]; then
		xclip -selection clipboard -t image/png -i /tmp/tempscreenshot.png
		notify-send "Screenshot copied" -u low -t 1000
		rm /tmp/tempscreenshot.png
	fi

elif [ "$1" = 'record' ]; then
	# Mod+r
	if [ ! -e /tmp/recpid ]; then
		# Record audio and video with ffmpeg
		killall statusbar; statusbar record &
		# shellcheck disable=SC2063
		ffmpeg -f x11grab -video_size "$(xrandr | grep '*' | awk '{print $1}')" \
			-framerate 30 -i "$DISPLAY" -f pulse -i default -c:v libx264 \
			-preset ultrafast -c:a aac ~/Videos/recording"$(date '+%Y%m%d%H%M%S')".mp4 &
					echo $! > /tmp/recpid
	fi

elif [ "$1" = 'stoprecord' ]; then
	# Mod+Shift+r
	if [ -e /tmp/recpid ]; then
		# Stop audio and video recording
		recpid="$(cat /tmp/recpid)"
		kill -2 "$recpid"
		killall statusbar; statusbar &
		notify-send "Recording stopped" -u low -t 1000
		sleep 4
		kill -9 "$recpid"
		rm -f /tmp/recpid
	fi
fi
