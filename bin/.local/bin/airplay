#!/bin/bash

if [ "$1" = 'start' ]; then
	if ! (systemctl is-active --quiet avahi-daemon); then
		#notify-send "AirPlay" -u critical -t 3000 "Insert password to start Avahi daemon"
		echo "Starting Avahi daemon"
		if ! sudo systemctl start avahi-daemon; then
			notify-send "AirPlay" -u low -t 3000 "Can't start Avahi"
			exit 0
		fi

		while [ "$(systemctl status avahi-daemon.service avahi-daemon.socket | grep -c "active (running)")" -lt 2 ]; do
			sleep 1
		done
		sleep 3 # TODO: wait for avahi to be completely initialized
	fi
	rpiplay &
	notify-send "AirPlay" -u low -t 3000 "Mirroring server started"

elif [ "$1" = 'stop' ]; then
	if [ "$(pgrep -c rpiplay)" -gt 1 ]; then
		#notify-send "AirPlay" -u critical -t 3000 "Insert password to stop avahi daemon"
		echo "Stopping avahi daemon"
		if ! sudo systemctl stop avahi-daemon.service avahi-daemon.socket; then
			notify-send "AirPlay" -u low -t 3000 "Avahi service still running"
		fi
		killall rpiplay
		notify-send "AirPlay" -u low -t 3000 "Mirroring server stopped"
	else
		notify-send "AirPlay" -u low -t 3000 "RPiPlay is not running"
	fi
fi
