#!/bin/sh

! echo "$1" | grep "https*://\S\+\.[A-Za-z]\+\S*" > /dev/null &&
	echo "That doesn't look like a full URL." && exit 1

YOUTUBE_REGEX='^(https?\:\/\/)?(www\.)?(youtube\.com|youtu\.?be)\/.+$'
RSSFILE="$HOME/.config/newsboat/urls"
arg="$1"

if echo "$arg" | grep -qE "$YOUTUBE_REGEX"; then
	info=$(curl -sfLS "$arg" | tr '<|>|,|\r' '\n')
	url=$(echo "$info" | awk -F'"' '/application\/rss\+xml/{print $8}')
	name=$(echo "$info" | grep '\"name\":' | cut -d '"' -f4)
	arg="$url \"~$name\""
fi

if awk '{print $1}' "$RSSFILE" | grep "^$arg$" > /dev/null; then
	echo "You already have this RSS feed."
	exit 1
else
	echo "$arg" >> "$RSSFILE"
	sort -o "$RSSFILE" "$RSSFILE"
fi
