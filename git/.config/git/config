[user]
	email = francesconicoletta@nomnp.com
	name = Francesco Nicoletta Puzzillo
[init]
	defaultBranch = master
[diff]
	tool = vimdiff
[difftool]
	prompt = false
[merge]
	tool = vimdiff
[mergetool "vimdiff"]
	path = nvim
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f

[includeIf "gitdir:~/Developer/amarula/"]
    path = ~/Developer/amarula/.gitconfig
